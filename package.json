{
  "name": "local-ocr-georgian-pdf",
  "version": "1.1.2",
  "description": "Desktop OCR app for scanned PDFs with built-in Georgian OCR runtime.",
  "main": "desktop/main.js",
  "author": "tazo",
  "license": "MIT",
  "scripts": {
    "postinstall": "node -e \"if(process.platform==='win32'){try{require('fs').accessSync('node_modules/electron/dist/electron.exe')}catch{require('child_process').execSync('powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-electron-win.ps1',{stdio:'inherit'})}}\"",
    "desktop:dev": "node desktop/run-dev.js",
    "desktop:reset-runtime": "node desktop/reset-runtime.js",
    "smoke:test": "node scripts/smoke-test.mjs",
    "security:audit": "npm audit --audit-level=high",
    "test:pdf": "node scripts/test-pdf.mjs",
    "desktop:icons": "node scripts/generate-icons.mjs",
    "desktop:icons:mac": "bash scripts/generate-icons.sh && node scripts/generate-icons.mjs",
    "desktop:bundle-runtime": "node desktop/bundle-runtime.js",
    "desktop:pack": "electron-builder --dir --publish never",
    "desktop:install": "bash scripts/install-mac.sh",
    "desktop:build": "electron-builder --mac dmg zip --win nsis --publish never",
    "desktop:build:mac": "electron-builder --mac dmg zip --publish never",
    "desktop:build:win": "electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "com.localocr.app",
    "productName": "Local OCR",
    "beforePack": "desktop/before-pack.js",
    "afterPack": "desktop/after-pack.js",
    "directories": {
      "output": "dist",
      "buildResources": "assets/icons"
    },
    "icon": "assets/icons/icon.png",
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "app.py",
        "to": "backend/app.py"
      },
      {
        "from": "templates",
        "to": "backend/templates"
      },
      {
        "from": "runtime",
        "to": "backend/runtime"
      },
      {
        "from": "build/bundled-runtime",
        "to": "backend/bundled-runtime"
      },
      {
        "from": "build/bundled-tools",
        "to": "backend/bundled-tools"
      },
      {
        "from": "LICENSE",
        "to": "backend/LICENSE"
      },
      {
        "from": "assets/icons",
        "to": "backend/assets/icons"
      }
    ],
    "asar": true,
    "artifactName": "Local-OCR-${os}-${arch}.${ext}",
    "mac": {
      "identity": null,
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icons/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Local OCR"
    }
  },
  "devDependencies": {
    "electron": "^40.10.2",
    "electron-builder": "^26.8.1",
    "to-ico": "^1.1.5"
  }
}
